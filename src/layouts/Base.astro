---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'harn.app — Harness Engineering', description = 'The interactive hub for Harness Engineering for AI coding agents' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daub-ui@latest/daub.css">
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:wght@300..900&family=Cabin:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/lucide@latest"></script>
  <style>
    :root {
      --harn-green: #34d399;
      --harn-dark: #0a0a0a;
    }
    body {
      background: var(--db-bg);
      color: var(--db-text);
      min-height: 100vh;
    }
    .harn-accent { color: var(--harn-green); }
    .harn-glow {
      text-shadow: 0 0 40px rgba(52, 211, 153, 0.3);
    }
    .harn-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 4rem 1.5rem;
    }
    .harn-hero {
      min-height: 80vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
    }
    .car-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 1.5rem;
    }
    .pillar-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }
    .timeline-track {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
      position: relative;
    }
    .timeline-track::before {
      content: '';
      position: absolute;
      top: 2rem;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(to right, #f59e0b, #3b82f6, var(--harn-green));
    }
    @media (max-width: 768px) {
      .timeline-track {
        grid-template-columns: 1fr;
      }
      .timeline-track::before {
        display: none;
      }
    }
    .failure-card:hover .failure-solution {
      max-height: 300px;
      opacity: 1;
      padding-top: 1rem;
    }
    .failure-solution {
      max-height: 0;
      opacity: 0;
      overflow: hidden;
      transition: all 0.3s ease;
    }
    pre code {
      font-size: 0.85rem;
    }
  </style>
</head>
<body>
  <slot />
  <script src="https://cdn.jsdelivr.net/npm/daub-ui@latest/daub.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      DAUB.setFamily('ink');
      DAUB.setScheme('dark');
      if (typeof lucide !== 'undefined') lucide.createIcons();
    });
  </script>
</body>
</html>
